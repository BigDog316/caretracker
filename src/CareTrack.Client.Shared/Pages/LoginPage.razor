@page "/login"
@inject CareTrackApi Api
@inject Microsoft.AspNetCore.Components.NavigationManager Nav

<PageTitle>Sign in — CareTrack</PageTitle>

<h1>Sign in</h1>

@if (_error is not null)
{
    <p class="error" role="alert" id="login-error">@_error</p>
}

<form @onsubmit="SubmitAsync" @onsubmit:preventDefault>
    <div class="field">
        <label for="email">Email</label>
        <input id="email" type="email" autocomplete="email" required
               @bind="_email" aria-describedby="@ErrorRef" />
    </div>
    <div class="field">
        <label for="password">Password</label>
        <input id="password" type="password" autocomplete="current-password" required
               @bind="_password" aria-describedby="@ErrorRef" />
    </div>
    <button type="submit" disabled="@_busy">
        @(_busy ? "Signing in…" : "Sign in")
    </button>
</form>

<p>New here? <a href="register">Create an account</a>.</p>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _busy;

    private string? ErrorRef => _error is null ? null : "login-error";

    protected override async Task OnInitializedAsync()
    {
        await Api.EnsureInitializedAsync();
        if (Api.IsAuthenticated) Nav.NavigateTo("");
    }

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            await Api.LoginAsync(_email.Trim(), _password);
            Nav.NavigateTo("");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException)
        {
            _error = "Couldn't reach the server. Check your connection and try again.";
        }
        finally
        {
            _busy = false;
        }
    }
}
